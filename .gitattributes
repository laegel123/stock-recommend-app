# 기본: 텍스트는 LF로 정규화 (Windows 에서도 working tree 를 LF 로 유지)
* text=auto eol=lf

# 셸 스크립트·git 훅은 반드시 LF — CRLF 면 `#!/usr/bin/env bash` 셰뱅이 깨져 실행 불가
*.sh         text eol=lf
.githooks/*  text eol=lf

# Windows 전용 스크립트는 CRLF
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf

# 바이너리(정규화·diff 금지)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
