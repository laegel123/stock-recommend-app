{
  "name": "stock-recommend-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @app/api run db:generate",
    "db:migrate": "pnpm --filter @app/api run db:migrate",
    "db:push": "pnpm --filter @app/api run db:push",
    "db:seed": "pnpm --filter @app/api run db:seed",
    "dev": "pnpm -r --parallel --if-present run dev",
    "dev:api": "pnpm --filter @app/api run dev",
    "dev:web": "pnpm --filter @app/web run dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@next/eslint-plugin-next": "^15.1.3",
    "@playwright/test": "^1.61.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^3.0.0"
  }
}
