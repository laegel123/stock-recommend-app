# 이 파일을 .env 로 복사해 채운다(.env 는 gitignore 됨). 실제 비밀키는 절대 커밋 금지.

# ── Database (docker-compose) ─────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=stockapp
DATABASE_URL=postgres://app:app@localhost:5432/stockapp

# ── Redis (BullMQ) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API ───────────────────────────────────────────────────
PORT=3001

# ── Web ───────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# ── 외부 데이터 소스 (Phase 1+) ───────────────────────────
# SEC EDGAR 는 키 불필요하나 User-Agent 필수(가드레일).
SEC_USER_AGENT=stock-recommend-app laegel1@gmail.com
# 금감원 DART OpenAPI 키(한국 fast-follow, Phase 2)
DART_API_KEY=
